{
  "expo": {
    "name": "Maqam",
    "slug": "maqam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "maqam",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D2818"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maqam.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2818"
      },
      "package": "com.maqam.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
